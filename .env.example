# Python ingestion and LLM analysis
LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Ingestion identities
SENDER_EMAIL=
EXCLUDED_EMAIL=
FORUM_AUTHOR_EMAIL=
WEBSITETOOLBOX_API_KEY=

# Shared application settings
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
RATIO_DATA_DIR=data
RATIO_OUTPUT_DIR=output

# Methodology settings
BASE_POSITION_SIZE=0.05
BENCHMARK_TOTAL_SCORE=20
FACTOR_COUNT=4
BETA_FLOOR=0.25
MAX_POSITION_SIZE=
DEFAULT_METHODOLOGY_VERSION=beta-v1
DEFAULT_CALCULATION_VERSION=beta-v1

# Rust API/backend settings
APP_NAME=ratio-api
DATABASE_URL=sqlite://data/ratio.db
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3000
